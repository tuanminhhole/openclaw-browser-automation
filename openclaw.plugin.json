{
  "id": "browser-automation",
  "name": "Browser Automation",
  "description": "Chrome/Chromium CDP browser controller. Supports real Chrome debug mode with headless Chromium fallback.",
  "version": "1.3.0",
  "enabledByDefault": true,
  "activation": {
    "onStartup": true,
    "onCapabilities": [
      "hook"
    ]
  },
  "capabilityTags": [
    "browser",
    "playwright",
    "chromium"
  ],
  "configSchema": {
    "type": "object",
    "properties": {
      "defaultProfile": {
        "type": "string",
        "description": "Default browser profile for CDP navigation.",
        "default": "host-chrome"
      }
    },
    "additionalProperties": false
  },
  "docker": {
    "apt": [
      "xvfb",
      "socat"
    ],
    "npmGlobal": [
      "playwright"
    ],
    "postInstallScripts": [
      "npx playwright install chromium --with-deps",
      "ln -f -s /root/.cache/ms-playwright/chromium-*/chrome-linux*/chrome /usr/bin/google-chrome 2>/dev/null || true"
    ],
    "extraHosts": [
      "host.docker.internal:host-gateway"
    ],
    "entrypoint": {
      "description": "Auto-detect host Chrome or start local headless Chromium",
      "position": "before-gateway"
    }
  },
  "skills": [],
  "providers": [],
  "channels": []
}
