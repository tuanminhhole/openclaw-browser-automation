{
  "name": "openclaw-browser-automation",
  "version": "1.3.3",
  "description": "Browser Automation plugin for OpenClaw. Controls Chrome/Chromium over CDP with real Chrome debug support.",
  "type": "module",
  "main": "index.js",
  "exports": "./index.js",
  "sideEffects": false,
  "files": [
    "index.js",
    "openclaw.plugin.json",
    "README.md",
    "README.vi.md",
    "browser-tool.js",
    "start-chrome-debug.bat",
    "start-chrome-debug.sh",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "browser",
    "automation",
    "browser-automation",
    "playwright",
    "cdp",
    "plugin"
  ],
  "author": "tuanminhole",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24",
      "minGatewayVersion": "2026.3.24"
    },
    "build": {
      "entry": "./index.js",
      "openclawVersion": "2026.3.24",
      "pluginSdkVersion": "2026.3.24"
    }
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "scripts": {
    "check": "node --check index.js"
  },
  "engines": {
    "node": ">=20"
  }
}
